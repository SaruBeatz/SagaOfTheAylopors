<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu"
    tools:context=".EndGameActivity">

    <!-- Background ImageView (celebratory/abstract) -->
    <ImageView
        android:id="@+id/backgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:contentDescription="End Game Background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Overlay with golden/celebratory tint -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#C0F5A623"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content Container -->
    <LinearLayout
        android:id="@+id/mainContentContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_parchment"
        android:padding="48dp"
        android:layout_marginHorizontal="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <!-- Completion Title -->
        <TextView
            android:id="@+id/completionTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сага завершена!"
            android:textColor="@color/color_accent"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="32dp"
            android:gravity="center" />

        <!-- Thank You Message -->
        <TextView
            android:id="@+id/thankYouTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Спасибо за прохождение!"
            android:textColor="@color/color_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="48dp"
            android:gravity="center" />

        <!-- Completion Message -->
        <TextView
            android:id="@+id/completionMessageTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Вы прошли все 7 глав саги. Ваше путешествие завершено, но приключения продолжаются..."
            android:textColor="@color/color_text_dark"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:layout_marginBottom="64dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:maxWidth="800dp" />

        <!-- Developer Info Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#30F5E6D3"
            android:padding="32dp"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Разработчик"
                android:textColor="@color/color_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/developerNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дмитрий Гурлив ПИм-404"
                android:textColor="@color/color_text_dark"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/developerEmailTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="dima.gurliv@gmail.com"
                android:textColor="@color/color_accent"
                android:textSize="18sp"
                android:fontFamily="serif"
                android:autoLink="email" />
        </LinearLayout>

        <!-- Return to Main Menu Button -->
        <Button
            android:id="@+id/mainMenuButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:minHeight="72dp"
            android:minWidth="300dp"
            android:text="@string/button_main_menu"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:background="@drawable/button_primary"
            android:textColor="@color/white"
            android:padding="20dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
