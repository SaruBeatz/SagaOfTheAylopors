<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu"
    tools:context=".DialogueActivity">

    <!-- Background ImageView -->
    <ImageView
        android:id="@+id/backgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/dialogue_chapter_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Overlay -->
    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#955D4037"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Bar with Chapter Title and Pause Button -->
    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#805D4037"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/chapterTitleTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dialogue_chapter_title"
            android:textColor="@color/color_accent"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat" />

        <Button
            android:id="@+id/pauseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_pause"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:background="@drawable/button_secondary"
            android:textColor="@color/color_text_light"
            android:padding="12dp"
            android:minHeight="40dp"
            android:minWidth="100dp" />
    </LinearLayout>

    <!-- Character Portrait - Top (for cat narrator) 
         NOTE: Currently disabled - view kept for future use but does not affect layout -->
    <ImageView
        android:id="@+id/characterPortraitImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:contentDescription="@string/speaker_puss"
        android:scaleType="centerInside"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@id/titleContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.4" />

    <!-- Text Area - Always at Bottom of Screen, Fixed Position -->
    <!-- NOTE: No longer depends on characterPortraitImageView for positioning -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/textArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_dialogue_box"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="180dp"
        android:maxHeight="280dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleContainer"
        app:layout_constraintVertical_bias="1.0">

        <!-- Character Portrait Overlay (for cat narrator) - Inside text area -->
        <ImageView
            android:id="@+id/characterPortraitOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:contentDescription="@string/speaker_puss"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.3" />

        <!-- Speaker Name -->
        <TextView
            android:id="@+id/speakerNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_parchment"
            android:fontFamily="@font/montserrat"
            android:padding="8dp"
            android:text="@string/speaker_narrator"
            android:textColor="@color/color_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Choice Indicator - Shows "..." when choices are available but not yet displayed -->
        <TextView
            android:id="@+id/choiceIndicatorTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:text="..."
            android:textColor="@color/color_accent"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:alpha="0.7"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Dialogue Text - Static (no scroll) -->
        <TextView
            android:id="@+id/dialogueTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/montserrat"
            android:gravity="top|start"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="8"
            android:padding="8dp"
            android:text="@string/test_dialog_line_1"
            android:textColor="@color/color_text_dark"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@id/choiceIndicatorTextView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/speakerNameTextView" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/choicesContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Choice buttons will be added dynamically -->
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
