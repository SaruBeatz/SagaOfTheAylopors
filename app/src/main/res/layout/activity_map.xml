<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_saga_map"
    tools:context=".MapActivity">

    <!-- Scrollable Map Container (background only) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mapScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:fadeScrollbars="true"
        android:scrollbars="none"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/startChapterButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Map Container FrameLayout (background only) -->
        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minHeight="800dp" />
    </androidx.core.widget.NestedScrollView>

    <!-- PathView for drawing animated paths between POIs -->
    <com.example.sagaoftheaylopors.PathView
        android:id="@+id/pathView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toTopOf="@id/startChapterButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Guidelines for percentage-based positioning -->
    <!-- Horizontal Guidelines (Y positions: 15%, 17%, 19%, 25%, 30%, 50%, 85%) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_15"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.15" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_17"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.17" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_19"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.19" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_25"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.43" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_30"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.30" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.50" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_y_85"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <!-- Vertical Guidelines (X positions: 15%, 25%, 50%, 60%, 70%, 80%, 85%, 90%) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_15"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.15" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_25"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.20" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.50" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_60"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.60" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_70"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.70" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_80"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.80" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_72"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.72" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_x_90"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.90" />

    <!-- Chapter 1: 15% width, 85% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode1"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_accent_dark"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_15"
        app:layout_constraintTop_toTopOf="@id/guideline_y_85"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_85"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Chapter 2: 25% width, 25% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode2"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_25"
        app:layout_constraintTop_toTopOf="@id/guideline_y_25"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_25"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/color_text_light"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Chapter 3: 60% width, 25% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode3"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_60"
        app:layout_constraintTop_toTopOf="@id/guideline_y_25"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_25"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/color_text_light"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Chapter 4: 50% width, 17% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode4"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_50"
        app:layout_constraintTop_toTopOf="@id/guideline_y_17"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_17"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/color_text_light"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Chapter 5: 85% width, 19% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode5"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_72"
        app:layout_constraintTop_toTopOf="@id/guideline_y_19"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_19"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="5"
            android:textColor="@color/color_text_light"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Chapter 6 (was 7): 80% width, 50% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode6"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_80"
        app:layout_constraintTop_toTopOf="@id/guideline_y_50"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_50"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="6"
            android:textColor="@color/color_text_light"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Chapter 7 (was 8): 70% width, 85% height -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chapterNode7"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/color_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/guideline_x_70"
        app:layout_constraintTop_toTopOf="@id/guideline_y_85"
        app:layout_constraintBottom_toBottomOf="@id/guideline_y_85"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="7"
            android:textColor="@color/color_text_light"
            android:textSize="24sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Start Chapter Button (centered, wrap content width) -->
    <Button
        android:id="@+id/startChapterButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:minHeight="56dp"
        android:text="@string/button_start_chapter"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:background="@drawable/button_primary"
        android:textColor="@color/white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>