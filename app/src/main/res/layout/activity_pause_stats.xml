<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#70000000"
    tools:context=".PauseActivity">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#705D4037"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/mainPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_parchment"
        android:padding="24dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginVertical="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginEnd="24dp">

            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pause_title"
                android:textColor="@color/color_accent"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:gravity="center_horizontal"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/statsTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pause_stats_title"
                android:textColor="@color/color_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/chaptersCompletedTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:layout_marginBottom="8dp"
                tools:text="Chapters completed: 2/7" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/statsTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dark"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"
                    android:fontFamily="@font/montserrat"
                    tools:text="Sociality: 0.50" />
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <Button
                android:id="@+id/resumeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:minHeight="56dp"
                android:text="@string/button_resume"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:background="@drawable/button_primary"
                android:textColor="@color/white"
                android:padding="12dp" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:minHeight="52dp"
                android:text="@string/button_save_game"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:background="@drawable/button_secondary"
                android:textColor="@color/color_text_light"
                android:padding="10dp" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:minHeight="52dp"
                android:text="@string/button_pause_settings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:background="@drawable/button_secondary"
                android:textColor="@color/color_text_light"
                android:padding="10dp" />

            <Button
                android:id="@+id/mainMenuButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:text="@string/button_main_menu"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat"
                android:background="@drawable/button_secondary"
                android:textColor="@color/color_text_light"
                android:padding="10dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
