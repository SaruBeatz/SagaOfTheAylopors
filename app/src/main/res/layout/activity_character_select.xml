<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu"
    tools:context=".CharacterSelectActivity">

    <!-- Background ImageView -->
    <ImageView
        android:id="@+id/backgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.6"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Base Overlay -->
    <ImageView
        android:id="@+id/characterBackgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/character_cat_name"
        android:scaleType="centerCrop"
        android:src="@drawable/cat_background"
        android:visibility="visible"
        tools:layout_editor_absoluteX="351dp"
        tools:layout_editor_absoluteY="93dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#805D4037"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/character_select_title"
        android:textColor="@color/color_accent"
        android:textSize="28sp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="20sp"
        android:autoSizeMaxTextSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/character_select_subtitle"
        android:textColor="@color/color_text_light"
        android:textSize="16sp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="16sp"
        android:gravity="center"
        android:shadowColor="#80000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleTextView" />

    <!-- Left Side: Full-Height Character Display (25% width) -->
    <ImageView
        android:id="@+id/characterFullHeightImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/cat_full_height"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="@string/character_cat_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleTextView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.25" />

    <!-- Right Side: Character Selection Frame (75% width) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/characterFrameCardView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#E05D4037"
        app:layout_constraintStart_toEndOf="@id/characterFullHeightImageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleTextView"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Background ImageView for Character Backgrounds -->

        <!-- Overlay to darken background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E05D4037" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Character Icons Horizontal Scroll -->
                <HorizontalScrollView
                    android:id="@+id/charactersScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fadeScrollbars="true"
                    android:scrollbars="none"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:id="@+id/charactersContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="4dp">

                        <!-- Character 1 - Cat (Selectable) -->
                        <FrameLayout
                            android:id="@+id/characterIconContainer1"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:id="@+id/characterIcon1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/character_card"
                                android:src="@drawable/cat_icon"
                                android:scaleType="centerCrop"
                                android:contentDescription="@string/character_cat_name"
                                android:clipToOutline="true" />
                        </FrameLayout>

                        <!-- Character 2 - King -->
                        <FrameLayout
                            android:id="@+id/characterIconContainer2"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:id="@+id/characterIcon2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/character_card"
                                android:src="@drawable/king_icon"
                                android:scaleType="centerCrop"
                                android:contentDescription="@string/character_king_name"
                                android:clipToOutline="true" />
                        </FrameLayout>

                        <!-- Character 3 - Princess -->
                        <FrameLayout
                            android:id="@+id/characterIconContainer3"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:id="@+id/characterIcon3"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/character_card"
                                android:src="@drawable/princess_icon"
                                android:scaleType="centerCrop"
                                android:contentDescription="@string/character_princess_name"
                                android:clipToOutline="true" />
                        </FrameLayout>

                        <!-- Character 4 - Ogre -->
                        <FrameLayout
                            android:id="@+id/characterIconContainer4"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:id="@+id/characterIcon4"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/character_card"
                                android:src="@drawable/ogre_icon"
                                android:scaleType="centerCrop"
                                android:contentDescription="@string/character_ogre_name"
                                android:clipToOutline="true" />
                        </FrameLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Character Information Section -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/characterInfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/color_background_parchment"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/characterInfoContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center"
                        android:visibility="visible">

                        <TextView
                            android:id="@+id/characterInfoName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="@font/montserrat"
                            android:textColor="@color/color_text_dark"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:text="@string/character_cat_name" />

                        <TextView
                            android:id="@+id/characterInfoDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="@font/montserrat"
                            android:textColor="@color/color_text_dark"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:text="@string/character_cat_desc" />

                        <TextView
                            android:id="@+id/characterInfoAvailability"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:textColor="@color/color_accent"
                            android:textSize="12sp"
                            android:textStyle="italic"
                            android:gravity="center"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Select as Companion Button -->
                <Button
                    android:id="@+id/selectCompanionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="@string/button_select_companion"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/montserrat"
                    android:background="@drawable/button_primary"
                    android:textColor="@color/white"
                    android:enabled="true"
                    android:clickable="true" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
