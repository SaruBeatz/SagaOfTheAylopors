<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FinalScreenActivity">

    <!-- Background ImageView -->
    <ImageView
        android:id="@+id/backgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_final_screen"
        android:scaleType="centerCrop"
        android:contentDescription="@string/final_screen_thank_you"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Semi-transparent Overlay for text readability -->
    <View
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#805D4037"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Thank You Message -->
    <TextView
        android:id="@+id/thankYouTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="120dp"
        android:text="@string/final_screen_thank_you"
        android:textColor="@color/color_accent"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="@font/montserrat"
        android:gravity="center"
        android:maxLines="3"
        android:ellipsize="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Player Statistics Container -->
    <LinearLayout
        android:id="@+id/statisticsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/thankYouTextView">

        <!-- Total Playtime -->
        <TextView
            android:id="@+id/totalPlaytimeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/final_screen_total_playtime"
            android:textColor="@color/color_text_light"
            android:textSize="20sp"
            android:textStyle="normal"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Button: Back to Main Menu -->
    <Button
        android:id="@+id/backToMainMenuButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:minHeight="64dp"
        android:text="@string/button_back_to_main_menu"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/montserrat"
        android:background="@drawable/button_primary"
        android:textColor="@color/white"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/developerInfoContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Developer Information Container -->
    <LinearLayout
        android:id="@+id/developerInfoContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Author -->
        <TextView
            android:id="@+id/authorTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/final_screen_author"
            android:textColor="@color/color_text_light"
            android:textSize="16sp"
            android:textStyle="normal"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            android:alpha="0.8"
            android:layout_marginBottom="8dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Email -->
        <TextView
            android:id="@+id/emailTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/final_screen_email"
            android:textColor="@color/color_text_light"
            android:textSize="16sp"
            android:textStyle="normal"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            android:alpha="0.8"
            android:autoLink="email"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>