<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark">

    <!-- Full-screen castle background -->
    <ImageView
        android:id="@+id/authBackgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main_menu_register_page"
        android:contentDescription="@null" />

    <!-- Cinematic dark overlay for readability -->
    <View
        android:id="@+id/authOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#C2000000" />

    <!-- Scrollable content – handles keyboard adjustResize properly -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/authScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            android:minHeight="1dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/authCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#F0E8DCC8"
                app:cardCornerRadius="16dp"
                app:cardElevation="24dp"
                app:layout_constraintWidth_max="560dp">

                <LinearLayout
                    android:id="@+id/authContentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:paddingTop="22dp"
                    tools:ignore="UselessParent">

                    <TextView
                        android:id="@+id/authTitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:gravity="center"
                        android:textColor="@color/color_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03"
                        tools:text="Sign in" />

                    <TextView
                        android:id="@+id/authSubtitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat"
                        android:gravity="center"
                        android:textColor="@color/color_text_dark"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3"
                        tools:text="Subtitle" />

                    <!-- Form fields inflated into this slot -->
                    <FrameLayout
                        android:id="@+id/authFormSlot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp" />

                    <ProgressBar
                        android:id="@+id/authProgressBar"
                        style="?android:attr/progressBarStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/authErrorText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/montserrat"
                        android:gravity="center"
                        android:textColor="#FFB71C1C"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="Error message" />

                    <Button
                        android:id="@+id/authPrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/button_primary_minimal"
                        android:fontFamily="@font/montserrat"
                        android:minHeight="48dp"
                        android:textColor="@color/color_accent"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        tools:text="Continue" />

                    <!-- Secondary link-style button: dark text, readable on parchment -->
                    <Button
                        android:id="@+id/authSecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/montserrat"
                        android:minHeight="44dp"
                        android:textColor="@color/color_primary"
                        android:textSize="13sp"
                        android:textStyle="normal"
                        tools:text="No account? Register" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
